# LLM Provider Configuration
# Supported providers: openai, anthropic
AGENTIC_LLM_PROVIDER=openai
AGENTIC_LLM_MODEL=gpt-4o
AGENTIC_LLM_API_KEY=
# For Anthropic, use:
# AGENTIC_LLM_PROVIDER=anthropic
# AGENTIC_LLM_MODEL=claude-sonnet-4-20250514
# AGENTIC_LLM_API_KEY=sk-ant-your-api-key-here

# Generation parameters
AGENTIC_TEMPERATURE=0.7
AGENTIC_MAX_TOKENS=4096

# Web scraping
AGENTIC_SCRAPING_RATE_LIMIT=10

# Newsletter schedule (daily, weekly)
AGENTIC_NEWSLETTER_SCHEDULE=daily

# Output directory for generated files
AGENTIC_OUTPUT_DIR=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
AGENTIC_LOG_LEVEL=INFO
